# ────────────────────────────────────────────────────────────────
# VoiceNote AI — environment variables
# Copy this file to ".env" and fill in the real values.
# NEVER commit your real .env to git. (.gitignore already ignores it.)
# ────────────────────────────────────────────────────────────────

# --- Twilio (WhatsApp) ---
# Found in the Twilio Console dashboard (https://console.twilio.com)
#
# TWO WAYS TO AUTHENTICATE:
#   A) CLASSIC: put your Account SID (AC...) here and Auth Token below.
#               Leave TWILIO_ACCOUNT_SID_AC blank.
#   B) API KEY: put your API Key SID (SK...) here, its Secret below, AND
#               your Account SID (AC...) in TWILIO_ACCOUNT_SID_AC.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Only needed if TWILIO_ACCOUNT_SID above is an API Key (SK...). Your AC... SID.
TWILIO_ACCOUNT_SID_AC=
# The Twilio WhatsApp sender. For the free sandbox this is always the number below.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- OpenAI ---
# Used for BOTH transcription (Whisper) AND analysis (chat completions).
# Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model used for the analysis step (cleanup + summary + key points).
# gpt-4o-mini is cheap, fast, multilingual, and reliably supports JSON mode.
OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# Languages your users actually speak. If Whisper auto-detects something
# OUTSIDE this list, we assume it mis-detected Sinhala and re-run forcing it.
WHISPER_SUPPORTED_LANGUAGES=english,sinhala,tamil
# Language code to force on the corrective retry (si = Sinhala).
WHISPER_FALLBACK_LANGUAGE=si

# --- Anthropic (OPTIONAL / NOT USED) ---
# The original spec mentioned Claude. This build uses OpenAI for analysis,
# so this is left here only for reference. Leave it blank.
ANTHROPIC_API_KEY=

# --- App config ---
# Free notes allowed per WhatsApp number PER DAY (resets at midnight).
FREE_DAILY_LIMIT=100
# Set to "true" in production so only genuine Twilio requests are accepted.
# Keep "false" for local testing / curl tests.
VALIDATE_TWILIO_SIGNATURE=false
# Port the Express server listens on.
PORT=3000
