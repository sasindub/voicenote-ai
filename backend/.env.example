# ────────────────────────────────────────────────────────────────
# WhatsApp Order Backend — environment variables
# Copy this to ".env" and fill in real values. NEVER commit .env.
# ────────────────────────────────────────────────────────────────

# --- MongoDB Atlas ---
# Your connection string from https://cloud.mongodb.com (Database → Connect →
# Drivers). Looks like:
#   mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/whatsapp_orders
MONGODB_URI=

# --- Twilio (WhatsApp) ---
# CLASSIC auth: Account SID (AC...) + Auth Token. Leave TWILIO_ACCOUNT_SID_AC blank.
# API KEY auth: API Key SID (SK...) + its Secret here, and your AC... SID in
#               TWILIO_ACCOUNT_SID_AC below.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID_AC=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- OpenAI --- (Whisper transcription + order extraction)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Whisper Sinhala-correction (auto-detect outside this set => retry as Sinhala)
WHISPER_SUPPORTED_LANGUAGES=english,sinhala,tamil
WHISPER_FALLBACK_LANGUAGE=si

# --- App ---
PORT=3000
# Set true in production so only genuine Twilio requests hit the webhook.
VALIDATE_TWILIO_SIGNATURE=false
# Allowed origin for the dashboard (the Next.js app URL). * = allow all (dev).
CORS_ORIGIN=*
